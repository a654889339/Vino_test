{
  "version": 1,
  "downloadDefault": {
    "readVia": "GET /api/media/cos?key={urlEncodedObjectKey}",
    "notesZh": "浏览器/小程序展示时推荐同源代理；桶 HTTPS 直链在 Web 端 resolveMediaUrl 会改写为上述路径。http 的 /uploads/ 相对路径也会映射到 key=vino/uploads/...。GET /api/media/cos-config 返回 cosHost 与 cosProxyAllowedPrefixes（与 services.CosProxyKeyPrefixWhitelist、IsKeyAllowedForProxy 同源）；变更白名单须同步改 cos.go 白名单与本 catalog 示例。",
    "keyPrefixExamples": ["vino/uploads/", "vino/main_page/", "vino/main_animation/", "vino/items/goods/", "vino/items/type/"]
  },
  "rules": [
    {
      "id": "toc_home_config_upload",
      "module": "ToC 首页/动画/页面基础等",
      "labelZh": "home_configs 图片上传（管理后台）",
      "upload": {
        "method": "POST",
        "path": "/api/home-config/upload",
        "formFields": ["file", "section（可选）", "role（flat 板块必填）"]
      },
      "cos": {
        "prefixPattern": "见 section：tabbar→vino/main_page；splash|headerLogo|homeBg→vino/main_animation；其它合法 section→vino/main_page/{section}；未传 section→vino/uploads",
        "namingNotes": "非 flat：{homeconfig-}{ms}-{rand}{ext}，thumb 子路径；flat：role 为 image/image_en 时用 UploadOriginalAndFlatCoverThumb（cover_thumbnail）；cover_thumbnail* 为固定文件名",
        "thumbBehavior": "mixed_tabbar_animation_flat"
      },
      "download": { "readVia": "api_media_cos_proxy", "notesZh": "与 downloadDefault 一致" }
    },
    {
      "id": "outlet_home_config_upload",
      "module": "服务商首页/动画/个人中心等",
      "labelZh": "outlet_home_configs 图片上传",
      "upload": {
        "method": "POST",
        "path": "/api/outlet/home-config/upload",
        "formFields": ["file", "section", "role"]
      },
      "cos": {
        "prefixPattern": "与 ToC 相同逻辑，随机文件前缀为 outlet-homeconfig-",
        "namingNotes": "复用 homeConfigImageUpload(c, \"outlet-homeconfig-\")",
        "thumbBehavior": "mixed_tabbar_animation_flat"
      },
      "download": { "readVia": "api_media_cos_proxy", "notesZh": "同 ToC" }
    },
    {
      "id": "guide_admin_upload",
      "module": "商品配置 DeviceGuide",
      "labelZh": "后台商品资源上传",
      "upload": {
        "method": "POST",
        "path": "/api/guides/admin/upload",
        "formFields": ["file", "guideId（可选）", "assetKind（可选）"]
      },
      "cos": {
        "prefixPattern": "无有效 guideId→vino/uploads；有→vino/items/goods/{guideId}",
        "namingNotes": "assetKind=icon|icon_en→固定 icon.ext / icon_en.ext；cover|cover_en→large_image* + cover_thumbnail*；cover_thumb|cover_thumb_en→仅缩略图 stem；model3d|model3d_decal|model3d_skybox→固定 glb/png 名；其它图片→guide-{ms}-{rand}{ext}+缩略图；非图→直传随机名",
        "thumbBehavior": "per_asset_kind"
      },
      "download": { "readVia": "api_media_cos_proxy", "notesZh": "商品详情 Web/小程序经 cosMedia 解析" }
    },
    {
      "id": "guide_admin_qrcode",
      "module": "商品配置",
      "labelZh": "后台生成绑定二维码 PNG",
      "upload": {
        "method": "POST",
        "path": "/api/guides/:id/qrcode",
        "formFields": ["JSON body force（可选）"]
      },
      "cos": {
        "prefixPattern": "vino/items/goods/{id}",
        "namingNotes": "固定文件名写入桶（覆盖策略见 guideGenerateQR）",
        "thumbBehavior": "none"
      },
      "download": { "readVia": "api_media_cos_proxy", "notesZh": "返回 URL 存 device_guides.qrcode_url" }
    },
    {
      "id": "product_category_upload",
      "module": "商品分类",
      "labelZh": "种类缩略图",
      "upload": {
        "method": "POST",
        "path": "/api/product-categories/upload",
        "formFields": ["file", "categoryId"]
      },
      "cos": {
        "prefixPattern": "vino/items/type/{categoryId}",
        "namingNotes": "large_image{ext} + cover_thumbnail（UploadOriginalAndFlatCoverThumb）",
        "thumbBehavior": "large_plus_cover_thumb"
      },
      "download": { "readVia": "api_media_cos_proxy", "notesZh": "同 downloadDefault" }
    },
    {
      "id": "auth_upload_avatar",
      "module": "ToC 用户",
      "labelZh": "用户头像",
      "upload": {
        "method": "POST",
        "path": "/api/auth/upload-avatar",
        "formFields": ["avatar"]
      },
      "cos": {
        "prefixPattern": "vino/uploads（defaultContentPrefix）",
        "namingNotes": "avatar_{16hex随机}{ext}",
        "thumbBehavior": "none"
      },
      "download": { "readVia": "api_media_cos_proxy", "notesZh": "profile 展示走 resolveMediaUrl" }
    },
    {
      "id": "outlet_auth_avatar",
      "module": "服务商用户",
      "labelZh": "门店/分销商头像",
      "upload": {
        "method": "POST",
        "path": "/api/outlet/auth/avatar",
        "formFields": ["avatar"]
      },
      "cos": {
        "prefixPattern": "vino/uploads",
        "namingNotes": "outlet_avatar_{16hex}{ext}",
        "thumbBehavior": "none"
      },
      "download": { "readVia": "api_media_cos_proxy", "notesZh": "同 ToC 头像" }
    },
    {
      "id": "message_upload_image",
      "module": "留言板 ToC",
      "labelZh": "用户聊天图片",
      "upload": {
        "method": "POST",
        "path": "/api/messages/upload-image",
        "formFields": ["image"]
      },
      "cos": {
        "prefixPattern": "vino/uploads",
        "namingNotes": "chat_{ms}_{8hex}{ext}",
        "thumbBehavior": "none"
      },
      "download": { "readVia": "api_media_cos_proxy", "notesZh": "消息内容存 URL 字符串" }
    },
    {
      "id": "outlet_message_upload_image",
      "module": "留言板 服务商",
      "labelZh": "门店用户聊天图片",
      "upload": {
        "method": "POST",
        "path": "/api/outlet/messages/upload-image",
        "formFields": ["image"]
      },
      "cos": {
        "prefixPattern": "vino/uploads",
        "namingNotes": "outlet_chat_{ms}_{8hex}{ext}",
        "thumbBehavior": "none"
      },
      "download": { "readVia": "api_media_cos_proxy", "notesZh": "同 ToC 留言图" }
    }
  ]
}
