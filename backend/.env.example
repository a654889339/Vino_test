NODE_ENV=development
PORT=5202

DB_HOST=localhost
DB_PORT=3308
DB_NAME=vino_db
DB_USER=root
DB_PASSWORD=vino_secret_2024

JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# 网页绑定商品页域名（库存导出二维码链接、绑定二维码）
FRONTEND_URL=http://localhost:5201

# 腾讯云 COS（上传 URL 与 CosBase() 一致；公网基址以 common/config/cos/vino.media.yaml 的 ossPublicBaseDefault 为准，可通过 VINO_MEDIA_CONFIG 指定文件路径；未设置 VINO_COS_* 时与现网默认桶相同）
# COS_SECRET_ID=
# COS_SECRET_KEY=
# VINO_COS_BUCKET=your-bucket-appid
# VINO_COS_REGION=ap-singapore

# 微信支付 APIv3（小程序 JSAPI，未配置则无法调起支付）
# WECHAT_PAY_ENABLED=false
# WECHAT_PAY_MCH_ID=
# WECHAT_PAY_MCH_SERIAL_NO=
# WECHAT_PAY_API_V3_KEY=
# WECHAT_PAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# WECHAT_PAY_PRIVATE_KEY_PATH=
# WECHAT_PAY_PLATFORM_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----\n"
# WECHAT_PAY_PLATFORM_CERT_PATH=
# WECHAT_PAY_NOTIFY_URL=https://你的域名/api/orders/wechat/notify
