.page {
  min-height: 100vh;
  background: #f6f6f8;
  box-sizing: border-box;
  padding: 20rpx 24rpx;
}

.loading,
.empty {
  padding: 80rpx 24rpx;
  text-align: center;
  color: #6b7280;
  font-size: 28rpx;
}

.link {
  display: inline-block;
  margin-top: 18rpx;
  color: #b91c1c;
  font-weight: 600;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 18rpx 16rpx;
  margin-bottom: 16rpx;
}

.row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.no {
  font-size: 26rpx;
  font-weight: 700;
  color: #111827;
}

.status {
  font-size: 22rpx;
  color: #6b7280;
}

.row2 {
  margin-top: 10rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.time {
  font-size: 22rpx;
  color: #9ca3af;
}

.price {
  font-size: 28rpx;
  color: #b91c1c;
  font-weight: 900;
}

