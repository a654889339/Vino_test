<view class="page">
  <view class="profile-header" style="{{profileHeaderStyle}}" bindtap="onProfileTap">
    <view class="avatar">
      <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill" />
      <text wx:else class="avatar-text">{{avatarInitial}}</text>
    </view>
    <view class="profile-info">
      <text class="profile-name">{{isLoggedIn ? (userInfo.nickname || userInfo.username || i18n.user) : i18n.tapLogin}}</text>
      <text class="profile-desc">{{isLoggedIn ? (maskedPhone || userInfo.email || '') : i18n.loginBenefits}}</text>
    </view>
  </view>

  <view class="mine-section">
    <view class="section-head">
      <text class="section-title">{{i18n.myOrders}}</text>
      <text class="section-link" bindtap="onAllGoodsOrdersTap">{{i18n.viewAllOrders}} ›</text>
    </view>
    <view class="order-card">
      <view class="order-stat-item" wx:for="{{stats}}" wx:key="key" data-status-group="{{item.key}}" bindtap="onStatTap">
        <view class="order-icon-wrap">
          <text class="order-icon-text">{{item.iconText}}</text>
          <text wx:if="{{item.value > 0}}" class="order-badge">{{item.value}}</text>
        </view>
        <text class="order-stat-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="mine-section">
    <view class="section-head">
      <text class="section-title">{{i18n.myCart}}</text>
      <text class="section-link" bindtap="onCartTap">{{i18n.view}} ›</text>
    </view>
    <view class="cart-summary-card" bindtap="onCartTap">
      <view wx:if="{{cartPreviewItems.length}}" class="cart-preview-list">
        <view class="cart-preview-item" wx:for="{{cartPreviewItems}}" wx:key="guideId">
          <image wx:if="{{item.imageUrl}}" src="{{item.imageUrl}}" mode="aspectFill" />
          <text wx:else class="cart-preview-empty">图</text>
        </view>
      </view>
      <text wx:else class="cart-empty-text">{{i18n.cartEmpty}}</text>
      <text class="cart-total-text">{{i18n.total}} {{cartTotalCount}} {{i18n.itemUnit}}</text>
    </view>
  </view>

  <view class="menu-card">
    <view
      class="menu-item"
      wx:for="{{menus}}"
      wx:key="title"
      data-index="{{index}}"
      bindtap="onMenuTap"
    >
      <image class="menu-icon" src="{{item.icon}}" mode="aspectFit" />
      <text class="menu-title">{{item.title}}</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="logout-area" wx:if="{{isLoggedIn}}">
    <button class="btn-logout" bindtap="logout">{{i18n.logout}}</button>
  </view>

  <view class="tab-bar-placeholder"></view>
</view>
