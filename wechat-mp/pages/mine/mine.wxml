<view class="page">
  <view class="profile-header" bindtap="onProfileTap">
    <view class="avatar">
      <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill" />
      <text wx:else class="avatar-text">{{avatarInitial}}</text>
    </view>
    <view class="profile-info">
      <text class="profile-name">{{isLoggedIn ? (userInfo.nickname || userInfo.username || '用户') : '点击登录'}}</text>
      <text class="profile-desc">{{isLoggedIn ? (userInfo.email || '') : '登录享更多权益'}}</text>
    </view>
  </view>

  <!-- 头像/昵称更新区域 -->
  <view class="edit-profile-card" wx:if="{{isLoggedIn}}">
    <view class="edit-row">
      <text class="edit-label">更换头像</text>
      <button class="edit-avatar-btn" open-type="chooseAvatar" bindchooseavatar="onUpdateAvatar">
        <text class="edit-btn-text">选择头像</text>
      </button>
    </view>
    <view class="edit-row">
      <text class="edit-label">修改昵称</text>
      <input type="nickname" class="edit-nickname-input" placeholder="点击修改" value="{{userInfo.nickname}}" bindblur="onUpdateNickname" />
    </view>
  </view>

  <view class="stats-row">
    <view class="stat-item" wx:for="{{stats}}" wx:key="label">
      <text class="stat-num">{{item.value}}</text>
      <text class="stat-label">{{item.label}}</text>
    </view>
  </view>

  <view class="menu-card">
    <view
      class="menu-item"
      wx:for="{{menus}}"
      wx:key="title"
      data-url="{{item.url}}"
      bindtap="onMenuTap"
    >
      <text class="menu-emoji">{{item.emoji}}</text>
      <text class="menu-title">{{item.title}}</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="logout-area" wx:if="{{isLoggedIn}}">
    <button class="btn-logout" bindtap="logout">退出登录</button>
  </view>

  <view class="tab-bar-placeholder"></view>
</view>
