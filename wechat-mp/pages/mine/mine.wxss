.page {
  min-height: 100vh;
  background: #f5f3ee;
}

.profile-header {
  position: relative;
  padding: 32rpx 32rpx 36rpx;
  display: flex;
  flex-direction: column;
  gap: 38rpx;
  background: #b91c1c;
  overflow: hidden;
}

.profile-brand {
  color: #fff;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.2;
}

.mine-lang-switch {
  position: absolute;
  top: 24rpx;
  right: 32rpx;
  min-width: 104rpx;
  height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.08);
}

.lang-part {
  color: #9ca3af;
  font-size: 21rpx;
  font-weight: 600;
  line-height: 1;
  transform: scale(0.92);
}

.lang-part.active {
  color: #7f1d1d;
  font-size: 24rpx;
  font-weight: 800;
  transform: scale(1);
}

.lang-divider {
  color: #d1d5db;
  font-size: 21rpx;
  font-weight: 600;
  line-height: 1;
}

.profile-main {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-img {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
}

.avatar-text {
  font-size: 48rpx;
  color: #fff;
  font-weight: 700;
}

.profile-name {
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.profile-desc {
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
  font-weight: 600;
}

.profile-assets {
  min-height: 136rpx;
  padding: 24rpx 0;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
}

.profile-asset {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  color: #fff;
}

.profile-asset-num {
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1;
}

.profile-asset-label {
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
  font-weight: 700;
}

.mine-section {
  margin: 0 32rpx 28rpx;
}

.profile-header + .mine-section {
  margin-top: 28rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 8rpx 14rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #111827;
}

.section-link {
  font-size: 24rpx;
  color: #8b8790;
}

.order-card,
.cart-summary-card {
  background: #fff;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.06);
}

.order-card {
  display: flex;
  padding: 26rpx 12rpx 24rpx;
}

.order-stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.order-icon-wrap {
  position: relative;
  width: 50rpx;
  height: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.order-status-icon {
  position: relative;
  width: 38rpx;
  height: 38rpx;
  color: #0f5f46;
  box-sizing: border-box;
}

.order-status-icon::before,
.order-status-icon::after,
.order-icon-detail,
.order-icon-detail::before,
.order-icon-detail::after {
  content: '';
  position: absolute;
  box-sizing: border-box;
}

.icon-balance-pay::before {
  left: 3rpx;
  top: 8rpx;
  width: 32rpx;
  height: 22rpx;
  border: 3rpx solid currentColor;
  border-radius: 5rpx;
}

.icon-balance-pay::after {
  left: 8rpx;
  top: 15rpx;
  width: 22rpx;
  border-top: 3rpx solid currentColor;
}

.icon-balance-pay .order-icon-detail {
  left: 9rpx;
  bottom: 8rpx;
  width: 10rpx;
  border-top: 3rpx solid currentColor;
}

.icon-logistics::before {
  left: 3rpx;
  top: 13rpx;
  width: 20rpx;
  height: 14rpx;
  border: 3rpx solid currentColor;
  border-radius: 3rpx;
}

.icon-logistics::after {
  right: 3rpx;
  top: 17rpx;
  width: 13rpx;
  height: 10rpx;
  border: 3rpx solid currentColor;
  border-left: none;
  border-radius: 0 4rpx 4rpx 0;
}

.icon-logistics .order-icon-detail::before,
.icon-logistics .order-icon-detail::after {
  bottom: 5rpx;
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: currentColor;
}

.icon-logistics .order-icon-detail::before {
  left: 9rpx;
}

.icon-logistics .order-icon-detail::after {
  right: 6rpx;
}

.icon-completed::before {
  left: 7rpx;
  top: 6rpx;
  width: 24rpx;
  height: 26rpx;
  border: 3rpx solid currentColor;
  border-radius: 5rpx;
}

.icon-completed::after {
  left: 13rpx;
  top: 17rpx;
  width: 13rpx;
  height: 8rpx;
  border-left: 3rpx solid currentColor;
  border-bottom: 3rpx solid currentColor;
  transform: rotate(-45deg);
}

.icon-comment::before {
  left: 5rpx;
  top: 7rpx;
  width: 28rpx;
  height: 22rpx;
  border: 3rpx solid currentColor;
  border-radius: 8rpx;
}

.icon-comment::after {
  left: 13rpx;
  bottom: 5rpx;
  width: 9rpx;
  height: 9rpx;
  border-left: 3rpx solid currentColor;
  border-bottom: 3rpx solid currentColor;
  background: #fff;
  transform: rotate(-35deg);
}

.icon-replay::before {
  left: 6rpx;
  top: 7rpx;
  width: 26rpx;
  height: 26rpx;
  border: 3rpx solid currentColor;
  border-left-color: transparent;
  border-radius: 50%;
  transform: rotate(-35deg);
}

.icon-replay::after {
  left: 4rpx;
  top: 6rpx;
  width: 11rpx;
  height: 11rpx;
  border-left: 3rpx solid currentColor;
  border-top: 3rpx solid currentColor;
  transform: rotate(-20deg);
}

.order-badge {
  position: absolute;
  top: -12rpx;
  right: -22rpx;
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #ef5b63;
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  line-height: 28rpx;
  text-align: center;
}

.order-stat-label {
  font-size: 24rpx;
  color: #111827;
}

.cart-summary-card {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 28rpx;
}

.cart-preview-list {
  flex: 1;
  display: flex;
  gap: 14rpx;
  min-width: 0;
}

.cart-preview-item {
  width: 76rpx;
  height: 76rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-preview-item image {
  width: 100%;
  height: 100%;
}

.cart-preview-empty,
.cart-empty-text,
.cart-total-text {
  font-size: 24rpx;
  color: #8b8790;
}

.cart-empty-text {
  flex: 1;
}

.cart-total-text {
  flex-shrink: 0;
}

.menu-card {
  background: #fff;
  border-radius: 16rpx;
  margin: 0 20rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.menu-title {
  flex: 1;
  font-size: 28rpx;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.logout-area {
  padding: 40rpx 32rpx;
}

.btn-logout {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  color: #666;
  background: #fff;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  text-align: center;
  padding: 0;
  margin: 0;
}

.tab-bar-placeholder {
  height: 120rpx;
}
