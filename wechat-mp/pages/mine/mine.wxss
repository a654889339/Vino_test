.profile-header {
  padding: 80rpx 40rpx 60rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-img {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
}

.avatar-text {
  font-size: 48rpx;
  color: #fff;
  font-weight: 700;
}

.profile-name {
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.profile-desc {
  color: rgba(255, 255, 255, 0.7);
  font-size: 24rpx;
}

.mine-section {
  margin: 0 32rpx 28rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 8rpx 14rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #111827;
}

.section-link {
  font-size: 24rpx;
  color: #8b8790;
}

.order-card,
.cart-summary-card {
  background: #fff;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.06);
}

.order-card {
  display: flex;
  padding: 26rpx 12rpx 24rpx;
}

.order-stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.order-icon-wrap {
  position: relative;
  width: 50rpx;
  height: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.order-icon-text {
  color: #0f5f46;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1;
}

.order-badge {
  position: absolute;
  top: -12rpx;
  right: -22rpx;
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #ef5b63;
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  line-height: 28rpx;
  text-align: center;
}

.order-stat-label {
  font-size: 24rpx;
  color: #111827;
}

.cart-summary-card {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 28rpx;
}

.cart-preview-list {
  flex: 1;
  display: flex;
  gap: 14rpx;
  min-width: 0;
}

.cart-preview-item {
  width: 76rpx;
  height: 76rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-preview-item image {
  width: 100%;
  height: 100%;
}

.cart-preview-empty,
.cart-empty-text,
.cart-total-text {
  font-size: 24rpx;
  color: #8b8790;
}

.cart-empty-text {
  flex: 1;
}

.cart-total-text {
  flex-shrink: 0;
}

.menu-card {
  background: #fff;
  border-radius: 16rpx;
  margin: 0 20rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.menu-title {
  flex: 1;
  font-size: 28rpx;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.logout-area {
  padding: 40rpx 32rpx;
}

.btn-logout {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  color: #666;
  background: #fff;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  text-align: center;
  padding: 0;
  margin: 0;
}

.tab-bar-placeholder {
  height: 120rpx;
}
