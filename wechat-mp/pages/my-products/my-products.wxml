<view class="page">
  <view class="add-bar">
    <button class="add-btn" bindtap="addProduct">{{i18n.addBtn}}</button>
  </view>
  <view class="empty" wx:if="{{!list.length && !loading}}">
    <text class="empty-icon">📦</text>
    <text class="empty-text">{{i18n.empty}}</text>
  </view>

  <view class="card" wx:for="{{list}}" wx:key="productKey">
    <view class="row">
      <text class="label">{{i18n.category}}</text>
      <text class="value">{{item.categoryName || '-'}}</text>
    </view>
    <view class="row">
      <text class="label">{{i18n.name}}</text>
      <text class="value">{{item.productName || item.productKey}}</text>
    </view>
    <view class="row">
      <text class="label">{{i18n.serial}}</text>
      <text class="value sn">{{item.productKey}}</text>
    </view>
    <view class="row">
      <text class="label">{{i18n.boundAt}}</text>
      <text class="value">{{item.boundAtStr}}</text>
    </view>
  </view>
</view>
