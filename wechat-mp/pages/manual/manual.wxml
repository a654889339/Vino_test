<view class="page">
  <view wx:if="{{loading}}" class="loading">{{loadingText}}</view>
  <block wx:else>
    <view class="header">
      <text class="main-title">{{guideName}} · {{manualSuffix}}</text>
      <text wx:if="{{helpItems.length > 1}}" class="chapter-count">{{chapterCountPrefix}} {{helpItems.length}} {{chapterCountSuffix}}</text>
    </view>

    <!-- TOC -->
    <view wx:if="{{helpItems.length > 1}}" class="toc-card">
      <text class="toc-title">{{tocTitle}}</text>
      <view wx:for="{{helpItems}}" wx:key="index" class="toc-item">
        <text class="toc-num">{{index + 1}}</text>
        <text class="toc-text">{{item.title}}</text>
      </view>
    </view>

    <!-- Chapters -->
    <view wx:for="{{helpItems}}" wx:key="index" class="chapter-card">
      <view class="chapter-header">
        <text class="chapter-num">{{index + 1}}</text>
        <text class="chapter-title">{{item.title}}</text>
      </view>
      <rich-text class="chapter-content" nodes="{{item.content}}" />
    </view>

    <view wx:if="{{manualPdfUrl}}" class="pdf-bar">
      <button class="pdf-btn" bindtap="onOpenManual">{{viewManualText}}</button>
    </view>
  </block>
</view>
