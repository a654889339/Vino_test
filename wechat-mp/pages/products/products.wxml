<view class="page">
  <view class="products-search-wrap">
    <view class="products-search-inner">
      <text class="products-search-icon" aria-hidden="true">🔍</text>
      <input
        class="products-search-input"
        type="text"
        placeholder="{{searchPlaceholder}}"
        placeholder-class="products-search-placeholder"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        confirm-type="search"
      />
      <view class="products-cart-btn" bindtap="goCart">
        <view class="cart-outline-icon cart-icon" aria-hidden="true">
          <view class="cart-outline-basket"></view>
          <view class="cart-outline-wheel cart-outline-wheel-left"></view>
          <view class="cart-outline-wheel cart-outline-wheel-right"></view>
        </view>
        <text class="products-cart-text">{{cartText}}</text>
        <text wx:if="{{cartCount > 0}}" class="cart-badge">{{cartCount}}</text>
      </view>
    </view>
  </view>

  <scroll-view
    wx:if="{{categories.length}}"
    scroll-x
    class="product-tabs"
    scroll-into-view="{{tabScrollKey}}"
    scroll-with-animation
  >
    <view
      class="tab-item {{selectedCategoryId === item.id ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="id"
      id="tab-{{item.id}}"
      data-id="{{item.id}}"
      bindtap="selectCategory"
    >{{item.displayName}}</view>
  </scroll-view>

  <view class="products-layout">
    <view class="product-main">
      <view wx:if="{{categoryBannerUrl}}" class="category-banner">
        <image class="category-banner-img" src="{{categoryBannerUrl}}" mode="widthFix" />
      </view>

      <view
        class="product-carousel"
        bindtouchstart="onListTouchStart"
        bindtouchmove="onListTouchMove"
        bindtouchend="onListTouchEnd"
        bindtouchcancel="onListTouchEnd"
      >
        <view class="product-carousel-track" style="{{trackStyle}}">
          <view class="product-carousel-page" wx:for="{{categoryPages}}" wx:key="id">
            <view wx:if="{{item.loading}}" class="main-loading">{{loadingText}}</view>
            <view wx:elif="{{item.filteredGuides.length}}" class="product-grid">
              <view
                class="grid-card"
                wx:for="{{item.filteredGuides}}"
                wx:for-item="guide"
                wx:key="id"
                data-id="{{guide.id}}"
                data-slug="{{guide.slug}}"
                bindtap="selectProduct"
              >
                <view class="grid-card-row">
                  <view class="grid-card-thumb">
                    <image wx:if="{{guide.displayImageUrl}}" src="{{guide.displayImageUrl}}" class="grid-card-thumb-img" mode="aspectFill" data-id="{{guide.id}}" />
                    <text wx:else class="grid-card-placeholder">📦</text>
                  </view>
                  <view class="grid-card-body">
                    <text class="grid-card-title">{{guide.displayName}}</text>
                    <text class="grid-card-subtitle">{{guide.displaySubtitle}}</text>
                    <text class="grid-card-desc">{{guide.displayDescription}}</text>
                    <view class="grid-card-price-row">
                      <view class="grid-card-price">
                        <text wx:if="{{guide.displayListPrice}}" class="price-now">{{guide.displayListPrice}}</text>
                        <text wx:else class="price-placeholder">—</text>
                        <text
                          wx:if="{{guide.displayOriginPrice && guide.originPrice && guide.originPrice > guide.listPrice}}"
                          class="price-origin"
                        >{{guide.displayOriginPrice}}</text>
                      </view>
                      <view class="add-cart-btn" data-id="{{guide.id}}" catchtap="addToCart">
                        <view class="cart-outline-icon add-cart-icon" aria-hidden="true">
                          <view class="cart-outline-basket"></view>
                          <view class="cart-outline-wheel cart-outline-wheel-left"></view>
                          <view class="cart-outline-wheel cart-outline-wheel-right"></view>
                        </view>
                      </view>
                    </view>
                  </view>
                </view>
              </view>
            </view>
            <view wx:elif="{{selectedCategoryId && !item.loading && item.guides.length && !item.filteredGuides.length}}" class="main-empty">{{noMatchText}}</view>
            <view wx:elif="{{selectedCategoryId && !item.loading && !item.guides.length}}" class="main-empty">{{noCategoryProductText}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{!listLoading && !categories.length}}" class="empty-hint">
    <text>{{noConfigText}}</text>
  </view>

  <view class="tab-bar-placeholder"></view>
</view>
