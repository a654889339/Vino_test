<view class="page">
  <view class="products-search-wrap">
    <view class="products-search-inner">
      <text class="products-search-icon" aria-hidden="true">🔍</text>
      <input
        class="products-search-input"
        type="text"
        placeholder="{{searchPlaceholder}}"
        placeholder-class="products-search-placeholder"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        confirm-type="search"
      />
      <view class="products-cart-btn" bindtap="goCart">
        <text class="cart-icon">🛒</text>
        <text wx:if="{{cartCount > 0}}" class="cart-badge">{{cartCount}}</text>
      </view>
    </view>
  </view>

  <scroll-view
    wx:if="{{categories.length}}"
    scroll-x
    class="product-tabs"
    scroll-into-view="{{tabScrollKey}}"
    scroll-with-animation
  >
    <view
      class="tab-item {{selectedCategoryId === item.id ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="id"
      id="tab-{{item.id}}"
      data-id="{{item.id}}"
      bindtap="selectCategory"
    >{{item.displayName}}</view>
  </scroll-view>

  <view class="products-layout">
    <view
      class="product-main"
      bindtouchstart="onListTouchStart"
      bindtouchend="onListTouchEnd"
    >
      <view wx:if="{{categoryBannerUrl}}" class="category-banner">
        <image class="category-banner-img" src="{{categoryBannerUrl}}" mode="widthFix" />
      </view>

      <view wx:if="{{listLoading}}" class="main-loading">{{loadingText}}</view>
      <view wx:elif="{{filteredDeviceGuides.length}}" class="product-grid">
        <view
          class="grid-card"
          wx:for="{{filteredDeviceGuides}}"
          wx:key="id"
          data-id="{{item.id}}"
          data-slug="{{item.slug}}"
          bindtap="selectProduct"
        >
          <view class="grid-card-row">
            <view class="grid-card-thumb">
              <image wx:if="{{item.displayImageUrl}}" src="{{item.displayImageUrl}}" class="grid-card-thumb-img" mode="aspectFill" data-id="{{item.id}}" />
              <text wx:else class="grid-card-placeholder">📦</text>
            </view>
            <view class="grid-card-body">
              <text class="grid-card-title">{{item.displayName}}</text>
              <text class="grid-card-subtitle">{{item.displaySubtitle}}</text>
              <text class="grid-card-desc">{{item.displayDescription}}</text>
              <view class="grid-card-price-row">
                <view class="grid-card-price">
                  <text wx:if="{{item.displayListPrice}}" class="price-now">{{item.displayListPrice}}</text>
                  <text wx:else class="price-placeholder">—</text>
                  <text
                    wx:if="{{item.displayOriginPrice && item.originPrice && item.originPrice > item.listPrice}}"
                    class="price-origin"
                  >{{item.displayOriginPrice}}</text>
                </view>
                <view class="add-cart-btn" data-id="{{item.id}}" catchtap="addToCart">
                  <text class="add-cart-icon">🛒</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
      <view wx:elif="{{selectedCategoryId && !listLoading && deviceGuides.length && !filteredDeviceGuides.length}}" class="main-empty">{{noMatchText}}</view>
      <view wx:elif="{{selectedCategoryId && !listLoading && !deviceGuides.length}}" class="main-empty">{{noCategoryProductText}}</view>
    </view>
  </view>

  <view wx:if="{{!listLoading && !categories.length}}" class="empty-hint">
    <text>{{noConfigText}}</text>
  </view>

  <view class="tab-bar-placeholder"></view>
</view>
