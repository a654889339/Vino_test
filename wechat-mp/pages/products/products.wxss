.page {
  position: relative;
  z-index: 1;
  background: #e8e8ed;
  min-height: 100vh;
}

.products-search-wrap {
  padding: 20rpx 24rpx 16rpx;
  box-sizing: border-box;
}

.products-search-inner {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #2d2d33;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
}

.products-search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  opacity: 0.85;
}

.products-search-input {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: #f3f4f6;
  height: 44rpx;
  line-height: 44rpx;
}

.products-search-placeholder {
  color: #9ca3af;
}

.category-banner {
  width: 100%;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #e5e7eb;
  line-height: 0;
}

.category-banner-img {
  width: 100%;
  display: block;
  vertical-align: top;
}

.products-layout {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  min-height: 360rpx;
  background: #ffffff;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.08);
}

.product-sidebar {
  flex-shrink: 0;
  width: 176rpx;
  padding: 0;
  background: #f7f6f2;
  border-right: 1rpx solid rgba(0, 0, 0, 0.08);
  box-sizing: border-box;
}

.sidebar-item {
  margin: 0;
  padding: 28rpx 20rpx 28rpx 24rpx;
  border-left: 6rpx solid transparent;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #4b5563;
  text-align: left;
  line-height: 1.35;
}

.sidebar-item.active {
  background: #e8e8e8;
  border-left-color: #07c160;
  color: #111827;
  font-weight: 600;
}

.product-main {
  flex: 1;
  min-width: 0;
  padding: 20rpx;
  background: #fafafa;
}

.main-loading {
  text-align: center;
  padding: 40rpx 0;
  color: #6b7280;
  font-size: 28rpx;
}

.main-empty {
  text-align: center;
  padding: 48rpx 24rpx;
  font-size: 28rpx;
  color: #6b7280;
}

/* 一行一个：左图右文，无白底框，图片区随素材自适应 */
.product-grid {
  display: flex;
  flex-direction: column;
  width: 100%;
  box-sizing: border-box;
}

.grid-card {
  width: 100%;
  box-sizing: border-box;
}

.grid-card-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  width: 100%;
  box-sizing: border-box;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.grid-card:last-child .grid-card-row {
  border-bottom: none;
}

.grid-card-icon {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  max-width: 200rpx;
  max-height: 160rpx;
}

.grid-card-img {
  max-width: 200rpx;
  max-height: 160rpx;
  width: auto;
  height: auto;
  display: block;
}

.grid-card-placeholder {
  font-size: 48rpx;
  line-height: 1;
}

.grid-card-name {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: #111827;
  font-weight: 600;
  text-align: left;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.empty-hint {
  text-align: center;
  padding: 80rpx 0;
  color: #6b7280;
  font-size: 14px;
}

.tab-bar-placeholder {
  height: 120rpx;
}
