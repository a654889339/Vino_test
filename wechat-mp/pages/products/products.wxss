.page {
  position: relative;
  z-index: 1;
  background: #e8e8ed;
  min-height: 100vh;
}

.products-search-wrap {
  padding: 20rpx 24rpx 16rpx;
  box-sizing: border-box;
}

.products-search-inner {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #2d2d33;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
}

.products-search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  opacity: 0.85;
}

.products-search-input {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: #f3f4f6;
  height: 44rpx;
  line-height: 44rpx;
}

.products-search-placeholder {
  color: #9ca3af;
}

.products-cart-btn {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 14rpx;
  margin-left: 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  background: rgba(255, 255, 255, 0.08);
}
.cart-icon {
  font-size: 28rpx;
}
.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 28rpx;
  height: 28rpx;
  line-height: 28rpx;
  padding: 0 6rpx;
  background: #ef4444;
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  border-radius: 999rpx;
  text-align: center;
}

.category-banner {
  width: 100%;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #e5e7eb;
  line-height: 0;
}

.category-banner-img {
  width: 100%;
  display: block;
  vertical-align: top;
}

.products-layout {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  min-height: 360rpx;
  background: #ffffff;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.08);
}

.product-sidebar {
  flex-shrink: 0;
  width: 176rpx;
  padding: 0;
  background: #f7f6f2;
  border-right: 1rpx solid rgba(0, 0, 0, 0.08);
  box-sizing: border-box;
}

.sidebar-item {
  margin: 0;
  padding: 28rpx 20rpx 28rpx 24rpx;
  border-left: 6rpx solid transparent;
  box-sizing: border-box;
  font-size: 26rpx;
  color: #4b5563;
  text-align: left;
  line-height: 1.35;
}

.sidebar-item.active {
  background: #e8e8e8;
  border-left-color: #07c160;
  color: #111827;
  font-weight: 600;
}

.product-main {
  flex: 1;
  min-width: 0;
  padding: 20rpx;
  background: #fafafa;
}

.main-loading {
  text-align: center;
  padding: 40rpx 0;
  color: #6b7280;
  font-size: 28rpx;
}

.main-empty {
  text-align: center;
  padding: 48rpx 24rpx;
  font-size: 28rpx;
  color: #6b7280;
}

/* 一行一个：左方形缩略图，右侧四行（名称、副标题、描述、价格） */
.product-grid {
  display: flex;
  flex-direction: column;
  width: 100%;
  box-sizing: border-box;
}

.grid-card {
  width: 100%;
  box-sizing: border-box;
}

.grid-card-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 20rpx;
  width: 100%;
  box-sizing: border-box;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.grid-card:last-child .grid-card-row {
  border-bottom: none;
}

.grid-card-thumb {
  flex-shrink: 0;
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: center;
}

.grid-card-thumb-img {
  width: 100%;
  height: 100%;
  display: block;
}

.grid-card-placeholder {
  font-size: 64rpx;
  line-height: 1;
}

.grid-card-body {
  flex: 1;
  min-width: 0;
  min-height: 200rpx;
  margin-top: 0;
  padding: 0 4rpx 0 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  text-align: left;
}

.grid-card-title {
  width: 100%;
  font-size: 28rpx;
  color: #111827;
  font-weight: 700;
  text-align: left;
  line-height: 1.35;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.grid-card-subtitle {
  width: 100%;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
  font-weight: 500;
  text-align: left;
  line-height: 1.35;
  min-height: 1.35em;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.grid-card-desc {
  width: 100%;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #9ca3af;
  text-align: left;
  line-height: 1.35;
  min-height: 1.35em;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.grid-card-price-row {
  margin-top: auto;
  padding-top: 12rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.price-placeholder {
  font-size: 28rpx;
  color: #9ca3af;
  font-weight: 600;
}

.grid-card-price {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 14rpx;
}

.price-now {
  color: #f59e0b;
  font-size: 32rpx;
  font-weight: 800;
}

.price-origin {
  color: #9ca3af;
  font-size: 22rpx;
  text-decoration: line-through;
}

.add-cart-btn {
  width: 68rpx;
  height: 68rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-cart-icon {
  font-size: 34rpx;
  line-height: 1;
}

.empty-hint {
  text-align: center;
  padding: 80rpx 0;
  color: #6b7280;
  font-size: 14px;
}

.tab-bar-placeholder {
  height: 120rpx;
}
