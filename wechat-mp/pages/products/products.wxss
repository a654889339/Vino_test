.page {
  position: relative;
  z-index: 1;
  background: #e8e8ed;
  min-height: 100vh;
}

.products-layout {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  min-height: 360rpx;
  background: #ffffff;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.08);
}

.product-sidebar {
  flex-shrink: 0;
  width: 176rpx;
  padding: 24rpx 0;
  background: #eef0f3;
  border-right: 1rpx solid rgba(0, 0, 0, 0.08);
  box-sizing: border-box;
}

.sidebar-item {
  margin: 0 16rpx 16rpx;
  padding: 20rpx 12rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #4b5563;
  text-align: center;
  line-height: 1.35;
}

.sidebar-item.active {
  background: rgba(255, 183, 77, 0.45);
  color: #111827;
  font-weight: 600;
}

.product-main {
  flex: 1;
  min-width: 0;
  padding: 20rpx;
  background: #fafafa;
}

.main-loading {
  text-align: center;
  padding: 40rpx 0;
  color: #6b7280;
  font-size: 28rpx;
}

.main-empty {
  text-align: center;
  padding: 48rpx 24rpx;
  font-size: 28rpx;
  color: #6b7280;
}

.product-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 16rpx;
}

.grid-card {
  width: calc(50% - 8rpx);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 12rpx;
  background: #ffffff;
  border: 1rpx solid rgba(0, 0, 0, 0.1);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.grid-card-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: #f3f4f6;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.grid-card-img {
  width: 100%;
  height: 100%;
}

.grid-card-placeholder {
  font-size: 40rpx;
}

.grid-card-name {
  font-size: 22rpx;
  color: #111827;
  font-weight: 600;
  text-align: center;
  line-height: 1.35;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.empty-hint {
  text-align: center;
  padding: 80rpx 0;
  color: #6b7280;
  font-size: 14px;
}

.tab-bar-placeholder {
  height: 120rpx;
}
