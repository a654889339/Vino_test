.page {
  min-height: 100vh;
  background: #f6f6f8;
  padding-bottom: 160rpx;
  box-sizing: border-box;
}

.loading,
.empty {
  padding: 80rpx 24rpx;
  text-align: center;
  color: #6b7280;
  font-size: 28rpx;
}

.link {
  display: inline-block;
  margin-top: 18rpx;
  color: #b91c1c;
  font-weight: 600;
}

.card {
  margin: 20rpx 24rpx 0;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 16rpx;
}

.row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(0,0,0,0.06);
}
.row:last-child { border-bottom: none; }

.row-ta { align-items: flex-start; }

.label {
  width: 120rpx;
  color: #111827;
  font-size: 26rpx;
}

.input {
  flex: 1;
  min-width: 0;
  text-align: right;
  font-size: 26rpx;
}

.ta {
  flex: 1;
  min-width: 0;
  min-height: 80rpx;
  text-align: right;
  font-size: 26rpx;
}

.hd {
  font-size: 26rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 8rpx;
}

.line {
  padding: 14rpx 0;
  border-top: 1rpx solid rgba(0,0,0,0.06);
}
.name { display:block; font-size: 26rpx; font-weight:700; color:#111827; }
.meta { display:block; margin-top: 6rpx; font-size: 22rpx; color:#6b7280; }
.lt { display:block; margin-top: 6rpx; font-size: 26rpx; color:#b91c1c; font-weight:800; text-align:right; }

.bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 24rpx;
  padding-bottom: max(18rpx, env(safe-area-inset-bottom));
  background: rgba(255,255,255,0.98);
  border-top: 1rpx solid rgba(0,0,0,0.06);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.total {
  font-size: 28rpx;
  color: #111827;
}

.total-num {
  color: #b91c1c;
  font-weight: 900;
  font-size: 34rpx;
}

.submit {
  flex-shrink: 0;
  width: 260rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  background: #b91c1c;
  color: #fff;
  font-weight: 700;
}

