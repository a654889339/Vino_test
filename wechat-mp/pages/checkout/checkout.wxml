<view class="page">
  <view wx:if="{{loading}}" class="loading">{{i18n.loading}}</view>

  <view wx:elif="{{!isLoggedIn}}" class="empty">
    <text>请先登录</text>
    <navigator url="/pages/login/login" class="link">去登录</navigator>
  </view>

  <view wx:elif="{{!lines.length}}" class="empty">
    <text>购物车为空</text>
    <navigator url="/pages/products/products" class="link">去选购</navigator>
  </view>

  <view wx:else>
    <view class="card">
      <view class="row">
        <text class="label">联系人</text>
        <input class="input" placeholder="请输入姓名" value="{{form.contactName}}" bindinput="onName" />
      </view>
      <view class="row">
        <text class="label">手机号</text>
        <input class="input" placeholder="请输入手机号" value="{{form.contactPhone}}" bindinput="onPhone" />
      </view>
      <view class="row row-ta">
        <text class="label">地址</text>
        <textarea class="ta" placeholder="请输入详细地址" value="{{form.address}}" bindinput="onAddr" />
      </view>
      <view class="row">
        <text class="label">备注</text>
        <input class="input" placeholder="可选" value="{{form.remark}}" bindinput="onRemark" />
      </view>
    </view>

    <view class="card">
      <view class="hd">商品明细</view>
      <view class="line" wx:for="{{lines}}" wx:key="guideId">
        <text class="name">{{item.name}}</text>
        <text class="meta">{{item.qty}} 件 · {{item.priceText}}</text>
        <text class="lt">{{item.lineTotalText}}</text>
      </view>
    </view>

    <view class="bottom">
      <view class="total">合计 <text class="total-num">{{totalText}}</text></view>
      <button class="submit" loading="{{submitting}}" bindtap="submit">提交订单</button>
    </view>
  </view>
</view>

