<view class="page">
  <!-- 独立背景层（与网页前台一致），背景图铺在底层 -->
  <view class="home-bg">
    <swiper wx:if="{{heroBgList.length}}" class="home-bg-swiper" autoplay circular interval="4000" indicator-dots indicator-color="rgba(255,255,255,0.5)">
      <block wx:for="{{heroBgList}}" wx:key="url">
        <swiper-item>
          <image class="home-bg-image" src="{{item.displayUrl}}" mode="aspectFill" data-idx="{{index}}" binderror="onHeroBgError" />
        </swiper-item>
      </block>
    </swiper>
    <image wx:elif="{{heroBgUrl}}" class="home-bg-image" src="{{heroBgUrl}}" mode="aspectFill" />
  </view>
  <!-- Hero 透明叠在背景上 -->
  <view class="hero">
    <view class="hero-overlay">
      <view class="hero-header">
        <image wx:if="{{headerLogoUrl}}" src="{{headerLogoUrl}}" class="hero-logo" mode="aspectFit" />
        <text wx:else class="hero-logo-text">VINO</text>
      </view>
    </view>
  </view>

  <!-- 自助预约 -->
  <view class="card-section" wx:if="{{navLgItems.length || navSmItems.length}}" style="{{homeScrollStyle}}">
    <view class="section-header">
      <text class="section-title">{{navSectionTitle}}</text>
      <text class="section-more" bindtap="goService">进度查询 ›</text>
    </view>
    <scroll-view scroll-x class="nav-lg-row" wx:if="{{navLgItems.length}}">
      <view class="nav-lg-item" wx:for="{{navLgItems}}" wx:key="id" bindtap="goPath" data-path="{{item.path}}">
        <view class="nav-lg-icon">
          <image wx:if="{{item.imageUrl}}" src="{{item.displayImageUrl}}" class="nav-lg-img" mode="aspectFill" data-id="{{item.id}}" data-kind="lg" binderror="onNavImageError" />
          <text wx:else class="nav-lg-emoji">🔧</text>
        </view>
        <text class="nav-lg-label" style="color:{{item.color || '#B91C1C'}}">{{item.title}}</text>
      </view>
    </scroll-view>
    <view class="nav-sm-row" wx:if="{{navSmItems.length}}">
      <view class="nav-sm-item" wx:for="{{navSmItems}}" wx:key="id" bindtap="goPath" data-path="{{item.path}}">
        <view class="nav-sm-icon">
          <image wx:if="{{item.imageUrl}}" src="{{item.displayImageUrl}}" class="nav-sm-img" mode="aspectFit" data-id="{{item.id}}" data-kind="sm" binderror="onNavImageError" />
          <text wx:else class="nav-sm-emoji">📋</text>
        </view>
        <text class="nav-sm-label">{{item.title}}</text>
      </view>
    </view>
  </view>

  <!-- Vino 产品（与网页一致） -->
  <view wx:if="{{vinoItems.length}}" class="vino-section" style="{{vinoSectionStyle}}">
    <view class="vino-inner">
      <view class="vino-head">
        <text class="vino-title">Vino产品</text>
        <text class="vino-more" bindtap="goProducts">全部 ›</text>
      </view>
      <view class="vino-grid">
        <view class="vino-cell" wx:for="{{vinoItems}}" wx:key="id" bindtap="goVinoGuide" data-slug="{{item.path}}">
          <view class="vino-icon-wrap">
            <image wx:if="{{item.iconUrlThumb || item.iconUrl}}" src="{{item.displayIconUrl}}" class="vino-icon-img" mode="aspectFit" data-idx="{{index}}" binderror="onVinoIconError" />
            <text wx:else class="vino-emoji">📦</text>
          </view>
          <text class="vino-name">{{item.title}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 甄选推荐 -->
  <view wx:if="{{featuredItems.length}}" class="fr-section" style="{{frSectionStyle}}">
    <view class="fr-head">
      <text class="fr-title">甄选推荐</text>
    </view>
    <scroll-view scroll-x class="fr-scroll" show-scrollbar="{{false}}" enable-flex="{{false}}">
      <view class="fr-card" wx:for="{{featuredItems}}" wx:key="id" bindtap="goFeaturedGuide" data-slug="{{item.path}}">
        <view class="fr-img-wrap">
          <image wx:if="{{item.coverUrl}}" class="fr-img" src="{{item.coverUrl}}" mode="widthFix" />
          <view wx:else class="fr-ph" />
        </view>
        <view class="fr-overlay">
          <text class="fr-t1">{{item.title}}</text>
          <text wx:if="{{item.subtitle}}" class="fr-t2">{{item.subtitle}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 我的商品：为空时整栏隐藏 -->
  <view wx:if="{{myProducts.length}}" class="card-section" style="{{myProductsSectionStyle}}">
    <view class="section-header">
      <text class="section-title">{{myProductsTitle}}</text>
      <text class="section-more" bindtap="goMyProducts">查看全部 ›</text>
    </view>
    <view class="my-products-list">
      <view class="my-product-item {{item.guideSlug || item.guide ? 'my-product-item--clickable' : ''}}" wx:for="{{myProducts}}" wx:key="productKey" bindtap="goMyProductGuide" data-slug="{{item.guideSlug || item.guide}}">
        <text class="my-product-category">{{item.categoryName || '-'}}</text>
        <view class="my-product-icon-wrap">
          <image wx:if="{{item.iconUrlThumb || item.iconUrl}}" src="{{item.displayIconUrl}}" class="my-product-icon" mode="aspectFit" data-idx="{{index}}" binderror="onMyProductIconError" />
          <text wx:else class="my-product-icon-placeholder">📦</text>
        </view>
        <text class="my-product-name">{{item.productName || item.productKey}}</text>
      </view>
    </view>
  </view>

  <!-- 探索 VINO（首页最下方） -->
  <view wx:if="{{exploreVino}}" class="explore-section">
    <view class="explore-head">
      <text class="explore-bar-title">{{exploreVino.barTitle}}</text>
    </view>
    <view class="explore-card" bindtap="goExploreVino">
      <block wx:if="{{exploreVino.displayBg}}">
        <view class="explore-media">
          <image class="explore-bg" src="{{exploreVino.displayBg}}" mode="widthFix" />
          <view class="explore-dim" />
          <view class="explore-center explore-center-overlay">
            <text class="explore-main">{{exploreVino.mainTitle}}</text>
            <text wx:if="{{exploreVino.subTitle}}" class="explore-sub">{{exploreVino.subTitle}}</text>
            <view class="explore-circle"><text class="explore-arrow">›</text></view>
          </view>
        </view>
      </block>
      <view wx:else class="explore-center explore-plain">
        <text class="explore-main-plain">{{exploreVino.mainTitle}}</text>
        <text wx:if="{{exploreVino.subTitle}}" class="explore-sub-plain">{{exploreVino.subTitle}}</text>
        <view class="explore-circle explore-circle-plain"><text class="explore-arrow-plain">›</text></view>
      </view>
    </view>
  </view>

  <view class="tab-bar-placeholder"></view>
</view>
