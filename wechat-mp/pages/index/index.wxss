.page {
  background: transparent;
  min-height: 100vh;
}

/* ===== Hero Section ===== */
.hero {
  height: 55vw;
  max-height: 640rpx;
  min-height: 400rpx;
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  background-size: cover;
  background-position: center;
  position: relative;
}

.hero-overlay {
  position: absolute;
  left: 0; right: 0; top: 0; bottom: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.12) 0%, rgba(0,0,0,0.02) 50%, rgba(255,255,255,0.08) 100%);
  display: flex;
  flex-direction: column;
}

.hero-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
}

.hero-logo {
  height: 56rpx;
  width: auto;
  max-width: 200rpx;
}

.hero-logo-text {
  color: #fff;
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

/* ===== Quick Nav ===== */
.nav-grid {
  display: flex;
  flex-wrap: wrap;
  background: #fff;
  padding: 30rpx 20rpx;
  margin-top: -30rpx;
  border-radius: 24rpx 24rpx 0 0;
  position: relative;
  z-index: 2;
}

.nav-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}

.nav-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.nav-icon-text {
  font-size: 40rpx;
}

.nav-label {
  font-size: 24rpx;
  color: #333;
}

/* ===== Card / Section ===== */
.card {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 16rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1d1d1f;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

/* ===== Hot Services ===== */
.service-scroll {
  white-space: nowrap;
}

.service-card {
  display: inline-block;
  width: 260rpx;
  margin-right: 16rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.service-cover {
  height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.service-icon-text {
  font-size: 64rpx;
}

.service-info {
  padding: 16rpx 20rpx;
}

.service-name {
  font-size: 28rpx;
  font-weight: 500;
  display: block;
  margin-bottom: 6rpx;
}

.service-desc {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.service-price {
  font-size: 30rpx;
  font-weight: 600;
  color: #B91C1C;
}

/* ===== Recommend ===== */
.recommend-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.recommend-item {
  width: 48%;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

.recommend-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.recommend-emoji {
  font-size: 40rpx;
}

.recommend-name {
  font-size: 28rpx;
  font-weight: 500;
  display: block;
  margin-bottom: 6rpx;
}

.recommend-desc {
  font-size: 22rpx;
  color: #999;
}

.tab-bar-placeholder {
  height: 120rpx;
}
