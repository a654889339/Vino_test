<view class="page">
  <view class="loading-wrap" wx:if="{{loading}}">
    <text>{{loadingText}}</text>
  </view>
  <block wx:else>
    <view class="detail-cover">
      <text class="detail-cover-icon">🔧</text>
    </view>
    <view class="detail-body">
      <text class="detail-title">{{serviceData.title}}</text>
      <text class="detail-desc">{{serviceData.description}}</text>
      <view class="price-row" wx:if="{{serviceData.showOriginPrice || serviceData.priceDisplay}}">
        <text class="detail-price" wx:if="{{serviceData.priceDisplay}}">{{serviceData.priceDisplay}}</text>
        <text class="origin-price" wx:if="{{serviceData.showOriginPrice}}">{{serviceData.originPriceDisplay}}</text>
      </view>

      <view class="section">
        <text class="section-title">{{highlightsTitle}}</text>
        <view class="feature-list">
          <view class="feature-item"><text class="feature-dot">·</text> {{highlight1}}</view>
          <view class="feature-item"><text class="feature-dot">·</text> {{highlight2}}</view>
          <view class="feature-item"><text class="feature-dot">·</text> {{highlight3}}</view>
          <view class="feature-item"><text class="feature-dot">·</text> {{highlight4}}</view>
        </view>
      </view>

      <view class="section">
        <text class="section-title">{{stepsTitle}}</text>
        <view class="steps">
          <text>1. {{step1}}</text>
          <text>2. {{step2}}</text>
          <text>3. {{step3}}</text>
          <text>4. {{step4}}</text>
          <text>5. {{step5}}</text>
        </view>
      </view>
    </view>

    <view class="detail-footer">
      <view class="btn-consult" bindtap="onConsult">💬 {{consultText}}</view>
      <button class="btn-book" type="default" hover-class="none" bindtap="onBookTap">{{bookNowText}}</button>
    </view>
  </block>

  <!-- Order Form Modal -->
  <view class="modal-mask" wx:if="{{showOrderForm}}" catchtouchmove="preventTouchMove" catchtap="closeOrderForm">
    <view class="modal-sheet" catchtap="preventClose" catchtouchmove="preventClose">
      <view class="modal-header">
        <text class="modal-title">{{modalTitle}}</text>
        <text class="modal-close" catchtap="closeOrderForm">×</text>
      </view>
      <view class="order-service-info">
        <view class="order-service-icon">🔧</view>
        <view>
          <text class="order-service-title">{{serviceData.title}}</text>
          <text class="order-service-price">{{serviceData.priceDisplay}}</text>
        </view>
      </view>

      <scroll-view class="modal-scroll" scroll-y show-scrollbar="{{true}}">
        <view class="form-group">
          <text class="form-label">{{labelContact}}</text>
          <input
            class="form-input"
            placeholder="{{phContact}}"
            value="{{contactName}}"
            maxlength="50"
            adjust-position="{{true}}"
            cursor-spacing="24"
            bindinput="inputContactName"
          />
        </view>
        <view class="form-group">
          <text class="form-label">{{labelPhone}}</text>
          <input
            class="form-input"
            type="digit"
            placeholder="{{phPhone}}"
            value="{{contactPhone}}"
            maxlength="11"
            adjust-position="{{true}}"
            cursor-spacing="24"
            bindinput="inputContactPhone"
          />
        </view>

        <view class="form-group">
          <text class="form-label">{{labelCategory}}</text>
          <picker
            wx:if="{{!productFieldsLocked}}"
            mode="selector"
            range="{{categoryPickerLabels}}"
            value="{{categoryPickerIndex}}"
            bindchange="onCategoryPickerChange"
          >
            <view class="picker-value">{{selectedCategoryId ? categoryPickerLabels[categoryPickerIndex] : phCategory + ' ▾'}}</view>
          </picker>
          <view wx:else class="picker-value picker-locked">{{categoryPickerLabels[categoryPickerIndex] || '-'}} 🔒</view>
        </view>

        <view class="form-group" wx:if="{{selectedCategoryId && filteredGuideLabels.length}}">
          <text class="form-label">{{labelProduct}}</text>
          <picker
            wx:if="{{!productFieldsLocked}}"
            mode="selector"
            range="{{filteredGuideLabels}}"
            value="{{guidePickerIndex}}"
            bindchange="onGuidePickerChange"
          >
            <view class="picker-value">{{selectedGuideId ? filteredGuideLabels[guidePickerIndex] : phProduct + ' ▾'}}</view>
          </picker>
          <view wx:else class="picker-value picker-locked">{{filteredGuideLabels[guidePickerIndex] || '-'}} 🔒</view>
        </view>

        <view class="form-group">
          <text class="form-label">{{labelSerial}}</text>
          <input
            class="form-input"
            placeholder="{{phSerial}}"
            value="{{productSerial}}"
            maxlength="128"
            adjust-position="{{true}}"
            cursor-spacing="24"
            bindinput="inputProductSerial"
            disabled="{{productFieldsLocked}}"
          />
        </view>

        <view class="form-group" wx:if="{{myProducts.length}}">
          <view class="my-product-header">
            <text class="form-label">{{labelMyProduct}}</text>
            <text wx:if="{{productFieldsLocked}}" class="unlock-btn" catchtap="unlockProductFields">{{clearSelText}}</text>
          </view>
          <picker
            mode="selector"
            range="{{productSerialPickerLabels}}"
            value="{{productSerialPickerIndex}}"
            bindchange="onMyProductSerialPick"
            disabled="{{productFieldsLocked}}"
          >
            <view class="picker-value picker-value-serial">{{productFieldsLocked ? productSerialPickerLabels[productSerialPickerIndex] + ' 🔒' : phMyProduct + ' ▾'}}</view>
          </picker>
        </view>

        <view class="form-group">
          <text class="form-label">{{labelCountry}}</text>
          <picker mode="selector" range="{{countryList}}" value="{{countryIndex}}" bindchange="onCountryChange">
            <view class="picker-value">{{country || phCountry}}</view>
          </picker>
        </view>

        <view class="form-group" wx:if="{{country === countryList[countryList.length - 1]}}">
          <text class="form-label">{{labelCustomCountry}}</text>
          <input class="form-input" placeholder="{{phCustomCountry}}" value="{{customCountry}}" maxlength="100" adjust-position="{{true}}" bindinput="inputCustomCountry" />
        </view>

        <view class="form-group" wx:if="{{country === countryList[0]}}">
          <text class="form-label">{{labelRegion}}</text>
          <picker mode="region" value="{{region}}" bindchange="onRegionChange">
            <view class="picker-value">{{region[0] && region[1] ? region[0] + ' ' + region[1] + (region[2] ? ' ' + region[2] : '') : phRegion}}</view>
          </picker>
        </view>

        <view class="form-group">
          <text class="form-label">{{labelAddress}}</text>
          <input
            class="form-input"
            placeholder="{{phAddress}}"
            value="{{detailAddress}}"
            maxlength="500"
            adjust-position="{{true}}"
            cursor-spacing="24"
            bindinput="inputDetailAddress"
          />
        </view>
        <view class="form-group">
          <text class="form-label">{{labelRemark}}</text>
          <textarea
            class="form-textarea"
            placeholder="{{phRemark}}"
            value="{{remark}}"
            maxlength="500"
            adjust-position="{{true}}"
            cursor-spacing="24"
            show-confirm-bar="{{false}}"
            bindinput="inputRemark"
          />
        </view>
      </scroll-view>

      <view class="form-submit">
        <view class="order-total">{{totalLabel}}<text wx:if="{{serviceData.priceDisplay}}" class="order-total-price">{{serviceData.priceDisplay}}</text></view>
        <button class="btn-submit" type="default" hover-class="none" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submitOrder">{{confirmBookText}}</button>
      </view>
    </view>
  </view>
</view>
