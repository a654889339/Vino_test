.page { background: #fff; min-height: 100vh; padding-bottom: 96px; }
.loading { text-align: center; padding: 60px 0; color: #999; }

.hero-block { background: #fff; margin-bottom: 10px; }
.hero { position: relative; min-height: 120px; overflow: visible; background: #fff; }
.hero-img { width: 100%; height: auto; display: block; }
.hero-fallback { min-height: 220px; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #333; }
.hero-icon-img { width: 64px; height: 64px; }
.hero-emoji { font-size: 56px; }
.hero-name { font-size: 22px; color: #fff; font-weight: 600; margin-top: 8px; }
.play-btn { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 50px; height: 50px; background: rgba(0,0,0,0.5); border-radius: 50%; color: #fff; font-size: 22px; display: flex; align-items: center; justify-content: center; line-height: 50px; text-align: center; }

.hero-media { padding: 16px; }
.hero-media-title { display: block; font-size: 16px; font-weight: 600; color: #1a1a1a; margin-bottom: 12px; }

.card { background: #fff; margin: 10px 12px; border-radius: 12px; padding: 16px; }
.title { display: block; font-size: 16px; font-weight: 600; color: #1a1a1a; margin-bottom: 12px; }

.media-scroll { white-space: nowrap; }
.media-card { display: inline-block; width: 130px; margin-right: 10px; vertical-align: top; }
.media-thumb-wrap { width: 130px; height: 160px; border-radius: 10px; overflow: hidden; position: relative; background: #1a1a1a; }
.media-thumb { width: 100%; height: 100%; }
.media-placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 28px; background: #2a2a2a; }
.media-play { position: absolute; top: 40%; left: 50%; transform: translate(-50%,-50%); width: 36px; height: 36px; background: rgba(0,0,0,0.5); border-radius: 50%; color: #fff; font-size: 14px; text-align: center; line-height: 36px; }
.media-label-overlay { position: absolute; bottom: 0; left: 0; right: 0; padding: 20px 8px 8px; background: linear-gradient(transparent, rgba(0,0,0,0.7)); }
.media-label-overlay text { font-size: 13px; font-weight: 600; color: #fff; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; display: block; }

.help-row { display: flex; justify-content: space-between; align-items: center; padding: 14px 0; border-bottom: 1px solid #f0f0f0; }
.help-row:last-child { border-bottom: none; }
.help-title { font-size: 14px; color: #333; }
.help-arrow { font-size: 18px; color: #ccc; }

.entry-grid { display: flex; justify-content: space-around; }
.entry-item { display: flex; flex-direction: column; align-items: center; gap: 6px; }
.entry-icon { width: 48px; height: 48px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 22px; }
.entry-item text:last-child { font-size: 12px; color: #666; }

.hero-3d-btn { position: absolute; right: 12px; bottom: 12px; display: inline-flex; align-items: center; gap: 4px; padding: 6px 14px; background: rgba(15,15,20,0.72); color: #fff; border-radius: 999px; font-size: 12px; font-weight: 500; z-index: 2; }
.hero-3d-btn:active { background: rgba(15,15,20,0.9); }
.hero-3d-icon { font-size: 12px; margin-right: 2px; }
.hero-3d-text { font-size: 12px; color: #fff; }

.viewer3d-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,0.92); z-index: 220; display: flex; align-items: center; justify-content: center; }
.viewer3d-overlay { position: relative; width: 94vw; height: 82vh; max-width: 900rpx; background: #0f0f14; border-radius: 14px; overflow: hidden; }
.viewer3d-overlay model-viewer { display: block; width: 100%; height: 100%; }
.viewer3d-close { position: absolute; top: 10px; right: 10px; width: 36px; height: 36px; line-height: 32px; text-align: center; border-radius: 50%; background: rgba(255,255,255,0.15); color: #fff; font-size: 26px; z-index: 3; }
.viewer3d-close:active { background: rgba(255,255,255,0.3); }
.viewer3d-tip { position: absolute; bottom: 10px; left: 50%; transform: translateX(-50%); font-size: 12px; color: rgba(255,255,255,0.72); padding: 4px 10px; border-radius: 999px; background: rgba(0,0,0,0.35); }

/* ===== Price Card ===== */
.price-card { background: #fff; margin: 10px 12px 18px; border-radius: 12px; padding: 16px; box-shadow: 0 1px 8px rgba(15,23,42,0.04); }
.price-row { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; }
.price-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 4px; }
.price-name { font-size: 16px; font-weight: 700; color: #1a1a1a; line-height: 1.35; white-space: normal; word-break: break-word; }
.price-subtitle { font-size: 13px; color: #64748b; line-height: 1.35; }
.price-desc { font-size: 12px; color: #94a3b8; line-height: 1.45; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.price-values { display: flex; align-items: baseline; gap: 8px; flex-shrink: 0; padding-top: 2px; }
.price-now { color: #b91c1c; font-size: 20px; font-weight: 800; }
.price-origin { color: #999; font-size: 13px; text-decoration: line-through; }

/* ===== Fixed Footer ===== */
.guide-footer-fixed { position: fixed; bottom: 0; left: 0; right: 0; z-index: 150; padding: 10px 16px; padding-bottom: calc(10px + env(safe-area-inset-bottom)); background: #fff; border-top: 1px solid rgba(0,0,0,0.06); }
.footer-inner { display: flex; align-items: center; justify-content: space-between; gap: 12px; max-width: 560px; margin: 0 auto; }
.footer-price { flex-shrink: 0; }
.footer-price-now { color: #b91c1c; font-size: 20px; font-weight: 800; }
.footer-btn-cart { flex-shrink: 0; min-width: 168px; height: 44px; display: inline-flex; align-items: center; justify-content: center; gap: 6px; padding: 0 22px; background: #ff9a76; color: #fff; border-radius: 999px; font-size: 14px; font-weight: 700; white-space: nowrap; box-shadow: 0 6px 14px rgba(249,115,22,0.18); box-sizing: border-box; }
.footer-btn-cart:active { opacity: 0.85; }

.cart-outline-icon { position: relative; width: 18px; height: 18px; color: currentColor; flex-shrink: 0; }
.cart-outline-icon::before { content: ''; position: absolute; left: 1px; top: 3px; width: 5px; height: 2px; border-top: 2px solid currentColor; transform: rotate(24deg); transform-origin: left center; }
.cart-outline-basket { position: absolute; left: 5px; top: 6px; width: 11px; height: 7px; border: 2px solid currentColor; border-top: none; border-radius: 0 0 3px 3px; box-sizing: border-box; }
.cart-outline-basket::before { content: ''; position: absolute; left: -1px; top: -5px; width: 13px; border-top: 2px solid currentColor; }
.cart-outline-wheel { position: absolute; bottom: 2px; width: 3px; height: 3px; background: currentColor; border-radius: 50%; }
.cart-outline-wheel-left { left: 7px; }
.cart-outline-wheel-right { right: 3px; }
