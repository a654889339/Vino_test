.page { background: #f5f5f5; min-height: 100vh; padding-bottom: 20px; }
.loading { text-align: center; padding: 60px 0; color: #999; }
.hero { position: relative; height: 220px; overflow: hidden; }
.hero-img { width: 100%; height: 100%; }
.hero-fallback { height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.hero-emoji { font-size: 56px; }
.hero-name { font-size: 22px; color: #fff; font-weight: 600; margin-top: 8px; }
.play-btn { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 50px; height: 50px; background: rgba(0,0,0,0.5); border-radius: 50%; color: #fff; font-size: 22px; display: flex; align-items: center; justify-content: center; line-height: 50px; text-align: center; }
.card { background: #fff; margin: 10px 12px; border-radius: 12px; padding: 16px; }
.title { display: block; font-size: 16px; font-weight: 600; color: #1a1a1a; margin-bottom: 12px; }
.desc { font-size: 14px; color: #666; line-height: 1.8; }
.media-scroll { white-space: nowrap; }
.media-card { display: inline-block; width: 140px; margin-right: 12px; vertical-align: top; position: relative; }
.media-thumb { width: 140px; height: 100px; border-radius: 10px; }
.media-placeholder { width: 140px; height: 100px; border-radius: 10px; background: #eee; display: flex; align-items: center; justify-content: center; font-size: 28px; }
.media-play { position: absolute; top: 38px; left: 55px; width: 30px; height: 30px; background: rgba(0,0,0,0.5); border-radius: 50%; color: #fff; font-size: 14px; text-align: center; line-height: 30px; }
.media-label { font-size: 12px; color: #333; margin-top: 6px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.tag-wrap { display: flex; flex-wrap: wrap; gap: 8px; }
.tag { display: inline-block; padding: 4px 12px; background: #FEE2E2; color: #B91C1C; border-radius: 20px; font-size: 13px; }
.help-row { display: flex; justify-content: space-between; align-items: center; padding: 14px 0; border-bottom: 1px solid #f0f0f0; }
.help-row:last-child { border-bottom: none; }
.help-title { font-size: 14px; color: #333; }
.help-arrow { font-size: 18px; color: #ccc; }
.section-block { margin-bottom: 16px; }
.section-block:last-child { margin-bottom: 0; }
.tip-row { display: flex; padding: 4px 0; }
.tip-dot { color: #B91C1C; margin-right: 8px; font-weight: bold; }
.tip-text { font-size: 13px; color: #666; line-height: 1.6; flex: 1; }
.entry-grid { display: flex; justify-content: space-around; }
.entry-item { display: flex; flex-direction: column; align-items: center; gap: 6px; }
.entry-icon { width: 48px; height: 48px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 22px; }
.entry-item text:last-child { font-size: 12px; color: #666; }
