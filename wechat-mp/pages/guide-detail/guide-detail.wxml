<view class="page">
  <view wx:if="{{loading}}" class="loading">{{loadingText}}</view>

  <block wx:elif="{{guide.id}}">
    <!-- Hero + Media merged block -->
    <view class="hero-block">
      <view class="hero" style="background:{{guide.gradient || '#333'}}">
        <image wx:if="{{guide.coverImage}}" src="{{guide.displayCoverUrl}}" class="hero-img" mode="aspectFill" bindtap="previewCover" bindload="onCoverLoad" binderror="onHeroImgError" />
        <view wx:else class="hero-fallback">
          <image wx:if="{{guide.iconUrl}}" src="{{guide.displayIconUrl}}" class="hero-icon-img" bindload="onIconLoad" binderror="onIconErr" />
          <text wx:else class="hero-emoji">{{guide.emoji}}</text>
          <text class="hero-name">{{guide.displayName || guide.name}}</text>
        </view>
        <view wx:if="{{guide.showcaseVideo}}" class="play-btn" bindtap="playShowcase">▶</view>
        <view wx:if="{{guide.model3dEnabled && guide.model3dUrl}}" class="hero-3d-btn" bindtap="open3DViewer">
          <text class="hero-3d-icon">◼</text>
          <text class="hero-3d-text">{{preview3DLabel}}</text>
        </view>
      </view>
      <view wx:if="{{mediaItems.length}}" class="hero-media">
        <text class="hero-media-title">{{firstMediaTitle}}</text>
        <scroll-view scroll-x class="media-scroll">
          <view wx:for="{{mediaItems}}" wx:key="index" class="media-card" bindtap="openMedia" data-item="{{item}}" data-index="{{index}}">
            <view class="media-thumb-wrap">
              <image wx:if="{{item.thumb}}" src="{{item.thumb}}" class="media-thumb" mode="aspectFill" />
              <view wx:else class="media-placeholder">{{item.type === 'video' ? '🎬' : '🖼'}}</view>
              <view wx:if="{{item.type === 'video'}}" class="media-play">▶</view>
              <view class="media-label-overlay">
                <text>{{item.title}}</text>
              </view>
            </view>
          </view>
        </scroll-view>
      </view>
    </view>

    <!-- Help Links -->
    <view wx:if="{{helpItems.length || sections.length || guide.manualPdfUrl}}" class="card">
      <text class="title">{{helpTitle}}</text>
      <view wx:if="{{helpItems.length || guide.manualPdfUrl}}" class="help-row" bindtap="goManual">
        <text class="help-title">{{manualLabel}}</text>
        <text class="help-arrow">›</text>
      </view>
      <view wx:if="{{sections.length}}" class="help-row" bindtap="goMaintenance">
        <text class="help-title">{{faqLabel}}</text>
        <text class="help-arrow">›</text>
      </view>
    </view>

    <!-- Service entries -->
    <view class="card">
      <text class="title">{{serviceEntryTitle}}</text>
      <view class="entry-grid">
        <view class="entry-item" bindtap="goServices">
          <view class="entry-icon" style="background:#EDE9FE"><text>🔧</text></view>
          <text>{{selfServiceLabel}}</text>
        </view>
        <view class="entry-item" bindtap="goServices">
          <view class="entry-icon" style="background:#DBEAFE"><text>📍</text></view>
          <text>{{servicePointLabel}}</text>
        </view>
        <view class="entry-item" bindtap="goServices">
          <view class="entry-icon" style="background:#D1FAE5"><text>🛡</text></view>
          <text>{{afterSalesLabel}}</text>
        </view>
        <view class="entry-item" bindtap="goServices">
          <view class="entry-icon" style="background:#FEF3C7"><text>💰</text></view>
          <text>{{repairQuoteLabel}}</text>
        </view>
      </view>
    </view>

    <!-- Price Info -->
    <view wx:if="{{hasPrice}}" class="price-card">
      <view class="price-row">
        <text class="price-name">{{guide.displayName || guide.name}}</text>
        <view class="price-values">
          <text wx:if="{{displayListPrice}}" class="price-now">{{displayListPrice}}</text>
          <text wx:if="{{displayOriginPrice}}" class="price-origin">{{displayOriginPrice}}</text>
        </view>
      </view>
    </view>
  </block>

  <!-- 底部固定操作栏 -->
  <view wx:if="{{hasPrice}}" class="guide-footer-fixed">
    <view class="footer-inner">
      <view class="footer-price">
        <text wx:if="{{displayListPrice}}" class="footer-price-now">{{displayListPrice}}</text>
      </view>
      <view class="footer-btn-cart" bindtap="addToCart">
        <view class="cart-outline-icon" aria-hidden="true">
          <view class="cart-outline-basket"></view>
          <view class="cart-outline-wheel cart-outline-wheel-left"></view>
          <view class="cart-outline-wheel cart-outline-wheel-right"></view>
        </view>
        <text>{{addCartLabel}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{show3DViewer}}" class="viewer3d-backdrop" catchtap="close3DViewer">
    <view class="viewer3d-overlay" catchtap="noop">
      <model-viewer id="modelViewer" canvas-id="product-model-canvas" bg-color="{{guide.model3dSkyboxBgColor || '#1a1a2e'}}" />
      <view class="viewer3d-close" catchtap="close3DViewer">×</view>
      <view wx:if="{{preview3DTip}}" class="viewer3d-tip">{{preview3DTip}}</view>
    </view>
  </view>
</view>
