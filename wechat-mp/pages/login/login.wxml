<view class="page">
  <view class="login-card">
    <view class="logo-area">
      <view class="logo-circle">
        <text class="logo-text">V</text>
      </view>
      <text class="app-name">{{welcomeText}}</text>
      <text class="app-desc">{{sloganText}}</text>
      <text wx:if="{{headerLogoDesc}}" class="header-logo-desc">{{headerLogoDesc}}</text>
    </view>

    <!-- 微信一键登录 -->
    <block wx:if="{{!isLoggedIn}}">
      <button class="btn-wx-login" loading="{{logging}}" disabled="{{logging}}" bindtap="wxLogin">
        <text wx:if="{{!logging}}">{{wxLoginText}}</text>
        <text wx:else>{{loggingText}}</text>
      </button>
      <text class="login-tip">{{agreementText}}</text>
    </block>

    <!-- 登录成功后设置头像和昵称（新用户） -->
    <block wx:if="{{isLoggedIn && showProfile}}">
      <view class="profile-setup">
        <text class="setup-title">{{setupTitle}}</text>
        <view class="avatar-area">
          <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
            <image wx:if="{{tempAvatarUrl}}" class="avatar-img" src="{{tempAvatarUrl}}" mode="aspectFill" />
            <view wx:else class="avatar-placeholder">
              <text class="avatar-placeholder-text">{{avatarPlaceholder}}</text>
            </view>
          </button>
        </view>
        <view class="nickname-area">
          <text class="field-label">{{nicknameLabel}}</text>
          <input type="nickname" class="nickname-input" placeholder="{{nicknamePlaceholder}}" value="{{tempNickname}}" bindinput="onNicknameInput" bindchange="onNicknameInput" />
        </view>
        <button class="btn-save" bindtap="saveProfile" loading="{{saving}}">{{saveAndEnter}}</button>
        <text class="skip-link" bindtap="skipProfile">{{skipText}}</text>
      </view>
    </block>
  </view>
</view>
