.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 60rpx 48rpx;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo-text {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: #B91C1C;
  margin-bottom: 24rpx;
}

.title {
  font-size: 36rpx;
  color: #333;
}

.form {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.form-input {
  height: 88rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.code-row {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.code-input {
  flex: 1;
}

.btn-code {
  width: 200rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 26rpx;
  color: #B91C1C;
  background: #fff;
  border: 1rpx solid #B91C1C;
  border-radius: 12rpx;
  padding: 0;
}

.btn-code[disabled] {
  color: #999;
  border-color: #ddd;
}

.btn-submit {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #B91C1C;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  margin-top: 20rpx;
}

.switch-mode {
  text-align: center;
  margin-top: 40rpx;
  font-size: 28rpx;
  color: #666;
}

.link {
  color: #B91C1C;
  margin-left: 8rpx;
}
