.page {
  min-height: 100vh;
  background: #f6f6f8;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

.loading,
.empty {
  padding: 80rpx 24rpx;
  text-align: center;
  color: #6b7280;
  font-size: 28rpx;
}

.link {
  display: inline-block;
  margin-top: 18rpx;
  color: #b91c1c;
  font-weight: 600;
}

.list {
  padding: 20rpx 24rpx;
}

.line {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  padding: 18rpx 16rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.line-left .img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #f3f4f6;
}

.line-left .ph {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.line-mid {
  flex: 1;
  min-width: 0;
}

.name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
}

.price {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #f59e0b;
  font-weight: 800;
}

.qty {
  display: flex;
  flex-direction: row;
  align-items: center;
  border: 1rpx solid rgba(0,0,0,0.08);
  border-radius: 999rpx;
  overflow: hidden;
}

.btn {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #111827;
  font-size: 30rpx;
}

.num {
  width: 64rpx;
  text-align: center;
  font-size: 26rpx;
  color: #111827;
}

.bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 24rpx;
  padding-bottom: max(18rpx, env(safe-area-inset-bottom));
  background: rgba(255,255,255,0.98);
  border-top: 1rpx solid rgba(0,0,0,0.06);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.total {
  font-size: 28rpx;
  color: #111827;
}

.total-num {
  color: #b91c1c;
  font-weight: 900;
  font-size: 34rpx;
}

.submit {
  flex-shrink: 0;
  width: 240rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  background: #b91c1c;
  color: #fff;
  font-weight: 700;
}

