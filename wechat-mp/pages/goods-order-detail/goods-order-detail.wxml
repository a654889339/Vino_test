<view class="page">
  <view wx:if="{{loading}}" class="loading">{{i18n.loading}}</view>

  <view wx:elif="{{!isLoggedIn}}" class="empty">
    <text>请先登录</text>
    <navigator url="/pages/login/login" class="link">去登录</navigator>
  </view>

  <view wx:elif="{{!order}}" class="empty">
    <text>订单不存在</text>
  </view>

  <view wx:else>
    <view class="card">
      <view class="kv"><text class="k">订单号</text><text class="v">{{order.orderNo}}</text></view>
      <view class="kv"><text class="k">状态</text><text class="v">{{order.status}}</text></view>
      <view class="kv"><text class="k">下单时间</text><text class="v">{{order.timeText}}</text></view>
      <view class="kv"><text class="k">联系人</text><text class="v">{{order.contactName}}</text></view>
      <view class="kv"><text class="k">手机号</text><text class="v">{{order.contactPhone}}</text></view>
      <view class="kv kv2"><text class="k">地址</text><text class="v2">{{order.address}}</text></view>
      <view class="kv kv2" wx:if="{{order.remark}}"><text class="k">备注</text><text class="v2">{{order.remark}}</text></view>
    </view>

    <view class="card">
      <view class="hd">商品明细</view>
      <view class="line" wx:for="{{order.items}}" wx:key="id">
        <text class="name">{{item.nameSnapshot}}</text>
        <text class="meta">{{item.qty}} 件 · {{item.unitText}}</text>
        <text class="lt">{{item.lineText}}</text>
      </view>
      <view class="sum">合计 <text class="sum-num">{{order.totalText}}</text></view>
    </view>
  </view>
</view>

