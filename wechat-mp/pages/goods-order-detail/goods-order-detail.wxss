.page {
  min-height: 100vh;
  background: #f6f6f8;
  box-sizing: border-box;
  padding: 20rpx 24rpx;
}

.loading,
.empty {
  padding: 80rpx 24rpx;
  text-align: center;
  color: #6b7280;
  font-size: 28rpx;
}

.link {
  display: inline-block;
  margin-top: 18rpx;
  color: #b91c1c;
  font-weight: 600;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 18rpx 16rpx;
  margin-bottom: 16rpx;
}

.kv {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 0;
  border-bottom: 1rpx solid rgba(0,0,0,0.06);
}
.kv:last-child { border-bottom: none; }

.kv2 { align-items: flex-start; }

.k {
  width: 140rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.v {
  color: #111827;
  font-size: 24rpx;
  font-weight: 600;
}

.v2 {
  flex: 1;
  text-align: right;
  color: #111827;
  font-size: 24rpx;
  line-height: 1.4;
}

.hd {
  font-size: 26rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 8rpx;
}

.line {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 14rpx 0;
  border-top: 1rpx solid rgba(0,0,0,0.06);
  gap: 16rpx;
}
.thumb {
  width: 96rpx;
  height: 96rpx;
  border-radius: 12rpx;
  background: #f3f4f6;
  flex-shrink: 0;
}
.thumb-empty {
  background: linear-gradient(135deg, #f3f4f6, #e5e7eb);
}
.line-body {
  flex: 1;
  min-width: 0;
}
.line-top {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
}
.name {
  flex: 1;
  font-size: 26rpx;
  font-weight: 700;
  color: #111827;
  line-height: 1.35;
}
.meta {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #6b7280;
}
.lt {
  flex-shrink: 0;
  font-size: 26rpx;
  color: #b91c1c;
  font-weight: 900;
}

.sum {
  margin-top: 10rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(0,0,0,0.06);
  text-align: right;
  font-size: 26rpx;
  color: #111827;
}
.sum-num {
  color: #b91c1c;
  font-weight: 900;
  font-size: 30rpx;
}

.status {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-weight: 600;
}
.status-pending { background: #fef3c7; color: #92400e; }
.status-paid { background: #dbeafe; color: #1e40af; }
.status-processing { background: #e0e7ff; color: #3730a3; }
.status-completed { background: #d1fae5; color: #065f46; }
.status-cancelled { background: #f3f4f6; color: #4b5563; }

.action-bar {
  margin-top: 24rpx;
  padding: 0 16rpx;
}
.btn-pay {
  width: 100%;
  padding: 24rpx 0;
  background: #b91c1c;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
  border-radius: 999rpx;
}
.btn-pay:active {
  opacity: 0.9;
}

