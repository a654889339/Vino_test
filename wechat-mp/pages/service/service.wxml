<view class="page">
  <view class="loading-wrap" wx:if="{{loading}}">
    <text>{{loadingText}}</text>
  </view>
  <view class="svc-body" wx:else>
    <view class="svc-section" wx:for="{{categories}}" wx:for-item="cat" wx:key="key">
      <text class="svc-section-title">{{cat.name}}</text>
      <view class="svc-card">
        <view class="svc-grid">
          <view
            class="svc-grid-item"
            wx:for="{{cat.items}}"
            wx:key="id"
            data-id="{{item.id}}"
            bindtap="goServiceDetail"
          >
            <view class="svc-icon-wrap">
              <image wx:if="{{item.iconUrl}}" class="svc-icon-img" src="{{item.iconUrl}}" mode="aspectFit" />
              <text wx:else class="svc-icon-emoji">{{item.emoji}}</text>
            </view>
            <text class="svc-item-name">{{item.title}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
  <view class="tab-bar-placeholder"></view>
</view>
