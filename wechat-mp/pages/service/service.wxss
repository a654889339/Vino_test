.page {
  min-height: 100vh;
  background: #f5f5f5;
}

.loading-wrap {
  padding: 80rpx 0;
  text-align: center;
  color: #999;
}

.svc-body {
  padding: 24rpx 24rpx 0;
}

.svc-section {
  margin-bottom: 32rpx;
}

.svc-section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #666;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.svc-card {
  background: #2a2a2e;
  border-radius: 24rpx;
  padding: 28rpx 16rpx 8rpx;
}

.svc-grid {
  display: flex;
  flex-wrap: wrap;
}

.svc-grid-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 0 24rpx;
}

.svc-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.svc-icon-img {
  width: 56rpx;
  height: 56rpx;
}

.svc-icon-emoji {
  font-size: 48rpx;
}

.svc-item-name {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  text-align: center;
  line-height: 1.3;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tab-bar-placeholder {
  height: 100rpx;
}
